        nav = nav + nav_link("/dashboard", "Dashboard") + nav_link("/logout", "Logout")
    } else {
        nav = nav + nav_link("/login", "Client login")
    }

    return "<!doctype html><html lang='en' class='scroll-smooth bg-[#05070b]'>" +
        "<head>" +
        "<script src='https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio'></script>" +
        "<meta name='viewport' content='width=device-width, initial-scale=1.0'>" +
        "<meta name='description' content='Evolvere Techne is a boutique software development consultancy at evolveretechne.com for AI systems, automation platforms, product engineering, and cloud infrastructure.'>" +
