    if error != nil && error != "" { notice = "<div class='rounded-2xl border border-red-400/30 bg-red-400/10 p-4 text-center text-red-100'>" + html_escape(error) + "</div>" }
    if message != nil && message != "" { notice = "<div class='rounded-2xl border border-emerald-400/30 bg-emerald-400/10 p-4 text-center text-emerald-100'>" + html_escape(message) + "</div>" }
    let content = "<main class='px-6 py-24'><div class='mx-auto max-w-md glass rounded-[2rem] p-8'>" +
        "<div class='mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-200 font-black text-slate-950'>ES</div>" +
        "<h1 class='mt-8 text-center text-3xl font-black text-white'>Client login</h1><p class='mt-3 text-center text-slate-400'>Prototype access for the TetherScript migration.</p>" + notice +
        "<form class='mt-8 space-y-4' action='/login' method='POST'>" +
        "<input name='username' type='text' required placeholder='Email or username' class='w-full rounded-2xl border-white/10 bg-white/10 text-white placeholder:text-slate-500'>" +
        "<input name='password' type='password' required placeholder='Password' class='w-full rounded-2xl border-white/10 bg-white/10 text-white placeholder:text-slate-500'>" +
        "<button type='submit' class='w-full rounded-2xl bg-cyan-200 px-5 py-3 font-bold text-slate-950 hover:bg-white'>Sign in</button>" +
        "</form></div></main>"
    return shell("Client Login", "", content)
}

fn dashboard_page(username) {
    let safe_username = html_escape(username)
    let content = "<main class='px-6 py-24'><div class='mx-auto max-w-5xl glass rounded-[2.5rem] p-10'>" + eyebrow("Client workspace") +
        "<h1 class='mt-6 text-5xl font-black tracking-tight text-white'>Hello, " + safe_username + ".</h1>" +
        "<p class='mt-5 max-w-2xl text-lg leading-8 text-slate-300'>Your Evolvere Techne workspace is ready for the next software engagement.</p>" +
        "</div></main>"
    return shell("Dashboard", username, content)
}

fn not_found_page(path) {
    let content = "<main class='grid min-h-[70vh] place-items-center px-6 py-24'><div class='text-center'>" + eyebrow("404") +
        "<h1 class='mt-6 text-5xl font-black text-white'>This route has not evolved yet.</h1>" +
        "<p class='mt-5 text-slate-400'>No route exists for " + html_escape(path) + ".</p>" +
        "<a href='/' class='mt-8 inline-flex rounded-full bg-cyan-200 px-7 py-4 text-sm font-bold text-slate-950'>Go home</a>" +
        "</div></main>"
    return shell("Not Found", "", content)
}

fn cookie_value(req, name) {
    if req.headers == nil { return "" }
    let cookie = req.headers["cookie"]
    if cookie == nil { return "" }
    let prefix = name + "="
    for part in str(cookie).split(";") {
        let item = part.trim()
        if item.starts_with(prefix) { return item.replace(prefix, "") }
    }
    return ""
}

fn with_session_cookie(resp, username) {
    resp.headers["set-cookie"] = "es_user=" + username + "; Path=/; HttpOnly; SameSite=Lax"
    return resp
}

fn clear_session_cookie(resp) {
    resp.headers["set-cookie"] = "es_user=; Path=/; Max-Age=0; HttpOnly; SameSite=Lax"
    return resp
}

fn static_file(req) {
    let path = req.path
    if path.contains("..") { return text(403, "forbidden\n") }
    let file = "." + path
    let body = fs.read(file)
    if body.is_err() { return html(404, not_found_page(path)) }
    return response(200, body.unwrap(), content_type(file))
}

fn handle(req) {
    let route = req.path
    if route.starts_with("/static/") || route == "/robots.txt" || route == "/favicon.ico" { return static_file(req) }
    if req.method == "GET" && route == "/" { return html(200, index_page()) }
    if req.method == "GET" && route == "/work" { return html(200, work_page()) }
    if req.method == "GET" && route == "/about" { return html(200, about_page()) }
    if req.method == "GET" && route == "/contact" { return html(200, contact_page()) }
    if req.method == "GET" && route == "/login" { return html(200, login_page("", "")) }
    if req.method == "POST" && route == "/login" {
        let form = parse_form(req.body)
        let username = form["username"]
        let password = form["password"]
        if username == nil || username == "" || password == nil || password == "" { return html(200, login_page("Invalid username or password", "")) }
        return with_session_cookie(redirect("/dashboard"), html_escape(username))
    }
    if req.method == "GET" && route == "/logout" { return clear_session_cookie(html(200, login_page("", "You have been logged out."))) }
    if req.method == "GET" && route == "/dashboard" {
        let username = cookie_value(req, "es_user")
        if username == nil || username == "" { return redirect("/login") }
        return html(200, dashboard_page(username))
    }
    return html(404, not_found_page(route))
}

fn main() {
    println("Starting Evolvere Techne TetherScript HTTP server on http://127.0.0.1:8787/")
    http_serve(8787, handle)
}
