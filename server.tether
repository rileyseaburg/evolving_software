    if username != nil && username != "" {
        nav = nav + nav_link("/dashboard", "Dashboard") + nav_link("/logout", "Logout")
    } else {
        nav = nav + nav_link("/login", "Client login")
    }

    return "<!doctype html><html lang='en' class='scroll-smooth bg-[#05070b]'>" +
        "<head>" +
        "<script src='https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio'></script>" +
        "<meta name='viewport' content='width=device-width, initial-scale=1.0'>" +
        "<meta name='description' content='Evolvere Techne is a boutique software development consultancy at evolveretechne.com for AI systems, automation platforms, product engineering, and cloud infrastructure.'>" +
        "<title>" + html_escape(title) + " - Evolvere Techne</title>" +
        "<style>body{background:radial-gradient(circle at 20% 0%,rgba(34,211,238,.18),transparent 32rem),radial-gradient(circle at 85% 15%,rgba(16,185,129,.16),transparent 28rem),#05070b}.glass{background:linear-gradient(135deg,rgba(255,255,255,.10),rgba(255,255,255,.04));border:1px solid rgba(148,163,184,.22);box-shadow:0 24px 80px rgba(0,0,0,.35)}.brand-grid{background-image:linear-gradient(rgba(148,163,184,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(148,163,184,.08) 1px,transparent 1px);background-size:42px 42px}</style>" +
        "</head>" +
        "<body class='min-h-screen text-slate-100 antialiased'>" +
        "<div class='brand-grid min-h-screen'>" +
        "<header class='sticky top-0 z-50 border-b border-white/10 bg-[#05070b]/80 backdrop-blur-xl'>" +
        "<nav class='mx-auto flex max-w-7xl items-center justify-between px-6 py-5'>" +
        "<a href='/' class='flex items-center gap-3'>" +
        "<span class='relative flex h-11 w-11 items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-cyan-300 via-emerald-300 to-slate-100 text-sm font-black text-slate-950 shadow-lg shadow-cyan-500/20'>ES</span>" +
        "<span><span class='block text-base font-semibold tracking-wide'>Evolvere Techne</span><span class='block text-[11px] uppercase tracking-[0.35em] text-cyan-200/70'>evolveretechne.com</span></span>" +
        "</a>" +
        "<div class='hidden items-center gap-8 md:flex'>" + nav + "</div>" +
        "</nav></header>" +
        content +
        footer() +
        "</div><script src='/static/js/index.js'></script></body></html>"
}

fn footer() {
    return "<footer class='border-t border-white/10 px-6 py-12'><div class='mx-auto flex max-w-7xl flex-col gap-6 md:flex-row md:items-center md:justify-between'>" +
        "<div><p class='font-semibold'>Evolvere Techne</p><p class='mt-1 text-sm text-slate-400'>Small senior teams for ambitious software. evolveretechne.com</p></div>" +
        "<div class='flex flex-wrap gap-3 text-xs uppercase tracking-[0.22em] text-slate-500'><span>AI</span><span>Automation</span><span>Cloud</span><span>Product</span><span>Mobile</span></div>" +
        "</div></footer>"
}

fn eyebrow(text_value) {
    return "<span class='inline-flex items-center rounded-full border border-cyan-300/25 bg-cyan-300/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-100'>" + text_value + "</span>"
}

fn stat(value, label) {
