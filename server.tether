// Evolvere Techne HTTP server implemented in TetherScript.
// Run: tetherscript run --grant-fs . server.tether

fn content_type(path) {
    if path.ends_with(".html") { return "text/html; charset=utf-8" }
    if path.ends_with(".css") { return "text/css; charset=utf-8" }
    if path.ends_with(".js") { return "application/javascript; charset=utf-8" }
    if path.ends_with(".json") { return "application/json" }
    if path.ends_with(".txt") { return "text/plain; charset=utf-8" }
    if path.ends_with(".svg") { return "image/svg+xml" }
    if path.ends_with(".ico") { return "image/x-icon" }
    if path.ends_with(".png") { return "image/png" }
    if path.ends_with(".jpg") { return "image/jpeg" }
    if path.ends_with(".jpeg") { return "image/jpeg" }
    if path.ends_with(".webp") { return "image/webp" }
    return "application/octet-stream"
}

fn response(status, body, content_type_value) {
    let resp = map()
    resp.status = status
    resp.body = body
    let headers = map()
    headers["content-type"] = content_type_value
    resp.headers = headers
    return resp
}

fn redirect(location) {
    let resp = map()
    resp.status = 302
    resp.body = ""
    let headers = map()
    headers["location"] = location
    headers["content-type"] = "text/plain; charset=utf-8"
    resp.headers = headers
    return resp
}

fn html(status, body) { return response(status, body, "text/html; charset=utf-8") }
fn text(status, body) { return response(status, body, "text/plain; charset=utf-8") }

fn html_escape(value) {
    let mut out = str(value)
    out = out.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out = out.replace("\"", "&quot;")
    out = out.replace("'", "&#39;")
    return out
}

fn url_decode(value) {
    let mut out = str(value)
    out = out.replace("+", " ")
    out = out.replace("%40", "@")
    out = out.replace("%2F", "/")
    out = out.replace("%3A", ":")
    out = out.replace("%20", " ")
    return out
}

fn parse_form(body) {
    let form = map()
    if body == nil || body == "" { return form }
    for pair in body.split("&") {
        if pair.contains("=") {
            let pieces = pair.split("=")
            form[url_decode(pieces[0])] = url_decode(pieces[1])
        }
    }
    return form
}

fn nav_link(href, label) {
    return "<a href='" + href + "' class='text-sm font-medium text-slate-300 hover:text-cyan-200 transition'>" + label + "</a>"
}

fn shell(title, username, content) {
